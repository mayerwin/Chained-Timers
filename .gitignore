.DS_Store
node_modules/
.cache/
.tmp/
.vscode/
.claude/
*.log

# Smoke-test scratch screenshots — keep only the curated docs/screenshots
screenshots/_*.png

# Capacitor build output
dist/

# Android — generated/build files (the project skeleton is committed)
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/app/release/
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
android/captures/
android/local.properties
android/*.iml
android/app/*.iml
# Android signing artifacts. The sideload keystore is committed (see
# android/app/build.gradle for the rationale); the upload keystore +
# its properties file are per-developer secrets and never committed.
publishing/android/upload.keystore
publishing/android/keystore.properties
# Build artifacts staged in publishing/ by 3-build-play-aab.ps1 (and the
# iOS counterpart). The originals stay under android/app/build/outputs/
# and ios/App/build/, but those deep paths are awkward to find when
# uploading to the stores -- the publishing scripts copy a versioned
# filename here for convenience. Always reproducible from `gradlew
# bundleRelease` / `xcodebuild`, never committed.
publishing/android/*.aab
publishing/android/*.apk
publishing/ios/*.ipa
publishing/ios/*.xcarchive/
# FGS_SPECIAL_USE demo screen recording uploaded to Play Console alongside
# the AAB. Reproducible from `adb shell screenrecord` against an emulator
# with the app sideloaded; not worth committing the binary on every push.
publishing/android/fgs-demo.mp4
# Backward-compatibility ignores for the v1.1.x layout where these
# lived at the repo root / under android/. Safe to keep.
android/keystore.properties
android/release.keystore
android/upload.keystore
upload.keystore
keystore.properties

# Publishing-time secrets (filled-in copy of publishing/secrets.template.md)
publishing/secrets.local.md
# Per-machine override for the Android publishing scripts (copy of
# publishing/android/local-config.ps1.example). Holds JDK / SDK paths.
publishing/android/local-config.ps1
# iOS distribution credentials
*.p12
*.p8
AuthKey_*.p8
# Play Console service account
play-service-account*.json

# iOS — generated/build files
ios/App/build/
ios/App/Pods/
ios/App/output/
ios/App/App/public/
ios/App/App/capacitor.config.json
ios/App/App/config.xml
ios/DerivedData/
ios/.idea/
*.xcuserstate
xcuserdata/
