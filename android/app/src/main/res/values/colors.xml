<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      App background. Must mirror the CSS bg token in css/styles.css.
      Used as android:windowBackground so the area behind the WebView
      (briefly visible during cold-start before the WebView paints, and
      between the system bars and the WebView while edge-to-edge insets
      are still being applied) matches the app's dark theme instead of
      flashing the AppCompat light/white default.
    -->
    <color name="appBg">#0E0D0B</color>

    <!--
      AppCompat / launcher fallback colours (referenced by AppTheme in
      styles.xml). Kept dark so any system surface that picks them up
      stays consistent with the rest of the UI.
    -->
    <color name="colorPrimary">#0E0D0B</color>
    <color name="colorPrimaryDark">#0E0D0B</color>
    <color name="colorAccent">#F5B042</color>
</resources>
